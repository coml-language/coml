(* Définition de l'indentation comme un nombre de colonnes *)
(* On suppose ici un espace comme unité, ou une tabulation *)
indent_unit   = " " | "\t" ;
indent        = { indent_unit } ;

(* Structure globale *)
config        = { root_section } ;
root_section  = "[" , identifier , "]" , "\n" , { block_content(0) } ;

(* Le contenu d'un bloc dépend de son niveau d'indentation *)
(* On utilise une règle récursive pour forcer la cohérence *)
block_content(n) = ( property(n) | subsection(n) ) ;

(* Une propriété doit avoir un niveau d'indentation supérieur au parent *)
property(n)      = indent_of(n + 1) , identifier , "=" , value , "\n" ;

(* Une sous-section définit un nouveau scope *)
subsection(n)    = indent_of(n + 1) , "[" , identifier , "]" , "\n" , { block_content(n + 1) } ;

(* Aide à la règle d'indentation *)
indent_of(n)     = { indent_unit } ; (* Dans l'implémentation, vérifier que le nombre est > n *)

(* Types de valeurs (TOML-like) *)
value         = string | integer | float | boolean | list | table ;
string        = '"' , { character } , '"' ;
integer       = [ "-" ] , digit , { digit } ;
float         = [ "-" ] , digit , { digit } , "." , digit , { digit } ;
boolean       = "true" | "false" ;
list          = "[" , [ value , { "," , value } ] , "]" ;
table         = { property | subsection } ;

identifier    = letter , { letter | digit | "_" } ;
